{
  "name": "react-native-boilerplate",
  "main": "expo-router/entry",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "start": "npx expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "bundle:aos": "cd android && rm -rf .gradle && npx expo run:android",
    "android": "npx expo run:android",
    "and": "npx react-native run-android",
    "ios": "cd MIBoilerplate/ && npx react-native run-ios",
    "dev": "EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start -c",
    "dev:ios": "EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --ios -c",
    "dev:android": "EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --android -c",
    "dev:web": "EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --web -c",
    "dev:doctor": "EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- npx expo-doctor",
    "dev:secret:push": "dotenvx run -f .env.dev -- eas secret:push --scope project --env-file .env.dev --force",
    "dev:secret:list": "dotenvx run -f .env.dev -- eas env:list",
    "dev:build:mobile": "npm run dev:secret:push && EXPO_NO_DOTENV=1 dotenv -e .env.dev -- npx eas build --profile development",
    "dev:build:web": "dotenvx run -f .env.dev -- npx expo export --platform web",
    "dev:serve:web": "dotenvx run -f .env.dev -- npx expo serve",
    "dev:deploy:web": "npm run dev:build:web && dotenvx run -f .env.dev -- eas deploy --environment development",
    "dev:config:public": "dotenvx run -f .env.dev -- npx expo config --type public",
    "lint": "expo lint",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "jest --verbose --passWithNoTests",
    "test:watch": "jest --verbose --passWithNoTests --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-query": "^5.90.11",
    "async-mutex": "^0.5.0",
    "axios": "^1.13.2",
    "expo": "~54.0.31",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-modules-core": "~3.0.29",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "jest": "~29.7.0",
    "pako": "^2.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.67.0",
    "react-native": "0.81.5",
    "react-native-gesture-bottom-sheet": "^1.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-material-ripple": "^0.9.1",
    "react-native-paper": "^5.14.5",
    "react-native-popover-view": "^6.1.0",
    "react-native-popup-menu": "^0.19.0",
    "react-native-reanimated": "^3.17.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-track-player": "^5.0.0-alpha0-nightly-359af5a12d712d3b685530aed9b9625865a25d74",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "redux-persist": "^6.0.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@dotenvx/dotenvx": "^1.33.0",
    "@react-native-community/cli": "^20.0.2",
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.12",
    "@types/pako": "^2.0.4",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^18.3.0",
    "@types/redux-logger": "^3.0.13",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.3",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.11",
    "lint-staged": "^15.4.1",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.4.2",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "^19.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "ws": "^8.13.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
